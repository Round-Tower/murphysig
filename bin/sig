#!/usr/bin/env bash
#
# Signed: Kev + claude-opus-4-6, 2026-03-23
# Prior: Kev + claude-opus-4-5-20250514, 2026-01-05
# Format: MurphySig v0.3.3 (https://murphysig.dev/spec)
#
# Context: MurphySig CLI v0.3.3 — "The Gruber Cut". Three key improvements:
# 1. sig review now actually writes the review into the file (was display-only)
# 2. Gallery/questions use grep discovery, not hardcoded file extensions
# 3. Agent mode: --reviewer/--text/--confidence flags for non-interactive use
#
# Confidence: 0.8 - core logic solid, agent mode needs real-world testing
# Open: Multi-line review entries? Comment block end detection edge cases?
#
# Reviews:
#
# 2026-01-05 (Kev + claude-haiku-4-5-20251001): Fixed parsing to only check
# first 50 lines, avoiding false matches in documentation examples.
#
# 2026-04-18 (Kev + claude-opus-4-7): Markdown comment style was outputting
# YAML frontmatter + split HTML Context/Open comments — non-spec shape and
# missing the Format: URL. Replaced with a single HTML comment block
# matching the xml style (spec-compliant, doesn't collide with existing
# frontmatter in .md files).

set -e

VERSION="0.3.3"
SPEC_URL="https://murphysig.dev/spec"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m' # No Color

# Get current date
TODAY=$(date +%Y-%m-%d)

# Get git user name if available
get_author() {
    if command -v git &> /dev/null && git config user.name &> /dev/null; then
        git config user.name
    else
        echo "${USER:-Unknown}"
    fi
}

# Detect comment style based on file extension
get_comment_style() {
    local file="$1"
    local ext="${file##*.}"

    case "$ext" in
        py|rb|sh|bash|zsh|yaml|yml|toml)
            echo "hash"
            ;;
        js|ts|jsx|tsx|java|kt|kts|swift|c|cpp|h|hpp|cs|go|rs|scala)
            echo "block"
            ;;
        html|xml|svg)
            echo "xml"
            ;;
        md|markdown)
            echo "markdown"
            ;;
        css|scss|sass|less)
            echo "css"
            ;;
        sql)
            echo "sql"
            ;;
        *)
            echo "hash"  # Default to hash comments
            ;;
    esac
}

# Extract comment prefix from existing signature (e.g. "# " or " * ")
get_comment_prefix() {
    local file="$1"
    head -50 "$file" 2>/dev/null | grep "Signed:" | head -1 | sed 's/Signed:.*//'
}

# Generate signature block
generate_signature() {
    local style="$1"
    local author="$2"
    local model="$3"
    local context="$4"
    local confidence="$5"
    local open="$6"

    local signed_by
    if [ -n "$model" ]; then
        signed_by="$author + $model"
    else
        signed_by="$author"
    fi

    case "$style" in
        hash)
            cat << EOF
# Signed: $signed_by, $TODAY
# Format: MurphySig v0.3.3 ($SPEC_URL)
#
# Context: $context
#
# Confidence: $confidence
# Open: $open

EOF
            ;;
        block)
            cat << EOF
/**
 * Signed: $signed_by, $TODAY
 * Format: MurphySig v0.3.3 ($SPEC_URL)
 *
 * Context: $context
 *
 * Confidence: $confidence
 * Open: $open
 */

EOF
            ;;
        xml)
            cat << EOF
<!--
  Signed: $signed_by, $TODAY
  Format: MurphySig v0.3.3 ($SPEC_URL)

  Context: $context

  Confidence: $confidence
  Open: $open
-->

EOF
            ;;
        markdown)
            cat << EOF
<!--
Signed: $signed_by, $TODAY
Format: MurphySig v0.3.3 ($SPEC_URL)

Context: $context

Confidence: $confidence
Open: $open
-->

EOF
            ;;
        css)
            cat << EOF
/*
 * Signed: $signed_by, $TODAY
 * Format: MurphySig v0.3.3 ($SPEC_URL)
 *
 * Context: $context
 *
 * Confidence: $confidence
 * Open: $open
 */

EOF
            ;;
        sql)
            cat << EOF
-- Signed: $signed_by, $TODAY
-- Format: MurphySig v0.3.3 ($SPEC_URL)
--
-- Context: $context
--
-- Confidence: $confidence
-- Open: $open

EOF
            ;;
    esac
}

# Preserve file permissions across temp file replacement (macOS stat)
safe_replace() {
    local tmp="$1"
    local target="$2"
    chmod "$(stat -f '%A' "$target")" "$tmp" 2>/dev/null || true
    mv "$tmp" "$target"
}

# Check if file has a signature (first 50 lines only)
has_signature() {
    local file="$1"
    head -50 "$file" 2>/dev/null | grep -q "^[[:space:]]*[-#/*]*[[:space:]]*Signed:" 2>/dev/null
}

# Extract signature info from file
get_signature_info() {
    local file="$1"
    local signed=$(head -50 "$file" 2>/dev/null | grep "Signed:" | head -1 | sed 's/.*Signed:[[:space:]]*//' | sed 's/[[:space:]]*\*\/.*//' | sed 's/[[:space:]]*$//')
    local confidence=$(head -50 "$file" 2>/dev/null | grep "Confidence:" | head -1 | sed 's/.*Confidence:[[:space:]]*//' | sed 's/[[:space:]]*\*\/.*//' | sed 's/[[:space:]]*$//')
    local reviews
    reviews=$(head -50 "$file" 2>/dev/null | grep -c "^[[:space:]]*[-#/*]*[[:space:]]*[0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}" 2>/dev/null) || reviews=0

    echo "$signed|$confidence|$reviews"
}

# Commands

cmd_init() {
    if [ -f ".murphysig" ]; then
        echo -e "${YELLOW}⚠${NC}  .murphysig already exists"
        return 0
    fi

    local author=$(get_author)

    cat > .murphysig << EOF
# This Project Uses MurphySig

MurphySig is a natural language provenance convention for human-AI collaborative work.

Full specification: $SPEC_URL

---

## For AI Systems

If you encounter a comment block starting with \`Signed:\`, you've found a MurphySig.

When modifying signed code:
1. Read the signature first
2. Respect stated confidence
3. Add a review documenting your changes

## CRITICAL: Never Fabricate Provenance

Do not invent signatures for files that lack them. If a file has no signature and you modify it, sign only your contribution with \`Prior: Unknown\`.

---

## Project Details

**Primary author**: $author
**Convention version**: MurphySig v0.3.3
**Initialized**: $TODAY
EOF

    echo -e "${GREEN}✓${NC}  Created .murphysig"
    echo -e "${DIM}   Add to your repo and AI assistants will respect the convention${NC}"
}

cmd_add() {
    local file="$1"

    if [ -z "$file" ]; then
        echo -e "${RED}✗${NC}  Usage: sig add <file>"
        exit 1
    fi

    if [ ! -f "$file" ]; then
        echo -e "${RED}✗${NC}  File not found: $file"
        exit 1
    fi

    if has_signature "$file"; then
        echo -e "${YELLOW}⚠${NC}  File already has a signature. Use 'sig review' to add a review."
        exit 1
    fi

    local author=$(get_author)
    local style=$(get_comment_style "$file")

    echo -e "${CYAN}Creating MurphySig for:${NC} $file"
    echo ""

    # Interactive prompts
    read -p "AI collaborator? (model version, or press Enter for none): " model
    read -p "Context - what were you thinking? " context
    read -p "Confidence (0.0-1.0): " confidence
    read -p "Open questions? " open

    # Set defaults
    context=${context:-"No context provided"}
    confidence=${confidence:-"0.5"}
    open=${open:-"None"}

    # Generate and prepend signature
    local sig=$(generate_signature "$style" "$author" "$model" "$context" "$confidence" "$open")
    local tmp=$(mktemp)

    echo "$sig" > "$tmp"
    cat "$file" >> "$tmp"
    safe_replace "$tmp" "$file"

    echo ""
    echo -e "${GREEN}✓${NC}  Signature added to $file"
}

cmd_review() {
    local file="$1"
    shift 2>/dev/null || true

    # Parse flags for non-interactive (agent) mode
    local flag_reviewer="" flag_text="" flag_confidence=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --reviewer) flag_reviewer="$2"; shift 2 ;;
            --text) flag_text="$2"; shift 2 ;;
            --confidence) flag_confidence="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [ -z "$file" ]; then
        echo -e "${RED}✗${NC}  Usage: sig review <file> [--reviewer NAME --text TEXT --confidence N]"
        exit 1
    fi

    if [ ! -f "$file" ]; then
        echo -e "${RED}✗${NC}  File not found: $file"
        exit 1
    fi

    if ! has_signature "$file"; then
        echo -e "${YELLOW}⚠${NC}  File has no signature. Use 'sig add' first."
        exit 1
    fi

    local author=$(get_author)
    local reviewer review_text new_confidence

    if [ -n "$flag_text" ]; then
        # Non-interactive (agent) mode
        reviewer="${flag_reviewer:-$author}"
        review_text="$flag_text"
        new_confidence="$flag_confidence"
    else
        # Interactive mode
        echo -e "${CYAN}Adding review to:${NC} $file"
        echo ""

        read -p "AI collaborator for this review? (or press Enter for none): " model
        read -p "What changed or what did you notice? " review_text
        read -p "Updated confidence? (or press Enter to keep current): " new_confidence

        if [ -n "$model" ]; then
            reviewer="$author + $model"
        else
            reviewer="$author"
        fi
    fi

    # Get comment prefix from existing signature
    local prefix=$(get_comment_prefix "$file")
    local blank_prefix
    blank_prefix=$(echo "$prefix" | sed 's/[[:space:]]*$//')

    # Build review entry
    local entry="${prefix}${TODAY} (${reviewer}): ${review_text}"
    if [ -n "$new_confidence" ]; then
        entry="${entry} Confidence now ${new_confidence}."
    fi

    # Insert into file
    local tmp=$(mktemp)
    local reviews_ln
    reviews_ln=$(head -50 "$file" | grep -n "Reviews:" | head -1 | cut -d: -f1)

    if [ -n "$reviews_ln" ]; then
        # Reviews section exists — insert after it
        head -n "$reviews_ln" "$file" > "$tmp"
        echo "$blank_prefix" >> "$tmp"
        echo "$entry" >> "$tmp"
        tail -n +"$((reviews_ln + 1))" "$file" >> "$tmp"
    else
        # No Reviews section — add one after Open: / Confidence: / Signed:
        local insert_ln
        insert_ln=$(head -50 "$file" | grep -n "Open:" | head -1 | cut -d: -f1)
        [ -z "$insert_ln" ] && insert_ln=$(head -50 "$file" | grep -n "Confidence:" | head -1 | cut -d: -f1)
        [ -z "$insert_ln" ] && insert_ln=$(head -50 "$file" | grep -n "Signed:" | head -1 | cut -d: -f1)

        if [ -z "$insert_ln" ]; then
            echo -e "${RED}✗${NC}  Could not find insertion point in signature block"
            rm "$tmp"
            exit 1
        fi

        head -n "$insert_ln" "$file" > "$tmp"
        echo "$blank_prefix" >> "$tmp"
        echo "${prefix}Reviews:" >> "$tmp"
        echo "$blank_prefix" >> "$tmp"
        echo "$entry" >> "$tmp"
        tail -n +"$((insert_ln + 1))" "$file" >> "$tmp"
    fi

    safe_replace "$tmp" "$file"

    echo ""
    echo -e "${GREEN}✓${NC}  Review added to $file"
    echo -e "${DIM}$entry${NC}"
}

cmd_gallery() {
    echo -e "${BOLD}Your Signed Work${NC}"
    echo ""

    local found=0

    # Grep-based discovery: find any file containing "Signed:" (skip binaries)
    while IFS= read -r file; do
        if has_signature "$file"; then
            found=1
            local info=$(get_signature_info "$file")
            local signed=$(echo "$info" | cut -d'|' -f1)
            local confidence=$(echo "$info" | cut -d'|' -f2)
            local reviews=$(echo "$info" | cut -d'|' -f3)

            echo -e "${GREEN}*${NC} ${BOLD}$file${NC}"
            echo -e "  ${DIM}$signed${NC}"
            echo -e "  Confidence: ${CYAN}$confidence${NC} | Reviews: $reviews"
            echo ""
        fi
    done < <(grep -rIl "Signed:" . 2>/dev/null | grep -v -e 'node_modules' -e '\.git/' -e '/dist/' -e '\.next/' -e '\.DS_Store' | sort)

    if [ $found -eq 0 ]; then
        echo -e "${DIM}No signed files found.${NC}"
        echo -e "${DIM}Use 'sig add <file>' to sign your first file.${NC}"
    fi

    echo ""
}

cmd_questions() {
    echo -e "${BOLD}Open Questions Across Your Work${NC}"
    echo ""

    local found=0

    while IFS= read -r file; do
        if has_signature "$file"; then
            local open=$(head -50 "$file" 2>/dev/null | grep -m1 "Open:" | sed 's/.*Open:[[:space:]]*//' | sed 's/[[:space:]]*\*\/.*//')
            if [ -n "$open" ] && [ "$open" != "None" ] && [ "$open" != "none" ]; then
                found=1
                echo -e "${CYAN}$file${NC}"
                echo -e "  $open"
                echo ""
            fi
        fi
    done < <(grep -rIl "Signed:" . 2>/dev/null | grep -v -e 'node_modules' -e '\.git/' -e '/dist/' -e '\.next/' -e '\.DS_Store' | sort)

    if [ $found -eq 0 ]; then
        echo -e "${DIM}No open questions found.${NC}"
    fi

    echo ""
}

cmd_help() {
    echo -e "${BOLD}sig${NC} - MurphySig CLI v$VERSION"
    echo ""
    echo -e "${BOLD}USAGE${NC}"
    echo "    sig <command> [arguments]"
    echo ""
    echo -e "${BOLD}COMMANDS${NC}"
    echo "    init              Initialize MurphySig in current project"
    echo "    add <file>        Add a signature to a file"
    echo "    review <file>     Add a review to a signed file"
    echo "    gallery           View all signed work in project"
    echo "    questions         List open questions across project"
    echo "    help              Show this help message"
    echo ""
    echo -e "${BOLD}REVIEW FLAGS${NC} (for agent/CI use)"
    echo "    --reviewer NAME   Who is reviewing (e.g. 'Kev + claude-opus-4-6')"
    echo "    --text TEXT        Review content"
    echo "    --confidence N     Updated confidence score"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo "    sig init"
    echo "    sig add src/auth.py"
    echo "    sig review src/auth.py"
    echo "    sig review src/auth.py --reviewer 'claude-opus-4-6' --text 'Security audit passed' --confidence 0.9"
    echo "    sig gallery"
    echo ""
    echo -e "${DIM}Full spec: $SPEC_URL${NC}"
}

# Main
case "${1:-}" in
    init)
        cmd_init
        ;;
    add)
        cmd_add "$2"
        ;;
    review)
        shift  # remove 'review'
        cmd_review "$@"
        ;;
    gallery)
        cmd_gallery
        ;;
    questions)
        cmd_questions
        ;;
    help|--help|-h)
        cmd_help
        ;;
    version|--version|-v)
        echo "sig v$VERSION"
        ;;
    "")
        cmd_help
        ;;
    *)
        echo -e "${RED}✗${NC}  Unknown command: $1"
        echo "Run 'sig help' for usage."
        exit 1
        ;;
esac
