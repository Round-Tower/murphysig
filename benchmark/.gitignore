# Environment
.env
.env.*

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv*/
venv/

# Results — the flat per-provider dirs are SCRATCH (overwrite on re-run);
# keep their raw JSON local. Commit .md reports from them.
results/*.json
results/**/*.json

# ...but archived runs ARE the committed record (manifest + verdicts +
# raw responses + report), snapshotted by scripts/archive_run.py. Each
# run-id dir is immutable, so re-runs never clobber history.
!results/honesty/runs/**

# OS
.DS_Store
