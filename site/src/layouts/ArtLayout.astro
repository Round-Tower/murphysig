---
/**
 * Signed: Kevin Murphy + gemini-2.0-flash-001, 2026-01-04
 * Format: MurphySig v0.3.3
 *
 * Context: The "Art" layout for murphysig.dev. Establishes the
 * typography-first aesthetic (Instrument Serif + JetBrains Mono).
 * Designed to feel like a printed manifesto.
 *
 * Confidence: 0.9 - standard Astro layout, minimal complexity.
 * Open: Should we enforce dark mode toggle or stick to "Paper"?
 *
 * Reviews:
 *
 * 2026-03-24 (Kev + claude-opus-4-6): SEO overhaul: fixed canonical URL passthrough, added OG image meta, twitter:image, summary_large_image card, initial-scale=1 viewport, security headers, cache headers Confidence now 0.9.
 *
 * 2026-01-06 (Kev + claude-opus-4-5-20251101): Added SEO meta tags,
 * Open Graph, Twitter cards, JSON-LD structured data for better
 * sharing and discovery.
 *
 * 2026-04-19 (Kev + claude-opus-4-7): Footer refresh — version bumped
 * v0.3.3 → v0.4, added /benchmark and home links to nav, added
 * monospace breadcrumb-style site identifier. Part of the "design
 * milestone 1" pass to make the site match the v0.4 spec.
 *
 * 2026-06-09 (Kev + claude-fable-5): Added /signed (registry) to the
 * footer nav alongside the new registry + badge surfaces.
 *
 * 2026-07-02 (Kev + claude-fable-5): Animation runtime for the eval
 * data graphics. html.js class (head, pre-paint) gates the mviz
 * reveal styles so no-JS readers get the final render; a body-end
 * IntersectionObserver adds .mviz-in on scroll and drives the
 * [data-countup] hero figures. Both respect prefers-reduced-motion.
 *
 * 2026-07-10 (Kev + claude-fable-5): SEO backlog pass. New optional
 * ogType prop (defaults to "website") so long-form posts can declare
 * og:type=article per page. Added /about to the footer nav.
 */

import '../styles/global.css';

interface Props {
	title: string;
    description?: string;
    canonical?: string;
    /**
     * Optional page-specific Schema.org JSON-LD. When provided, replaces
     * the default homepage WebSite schema. Pass plain objects; will be
     * stringified at render. Sub-pages should override this so search
     * engines see TechArticle / Dataset / BlogPosting per page rather
     * than a duplicated WebSite stub on every URL.
     */
    schemaJson?: object;
    /** Open Graph object type. "article" for long-form posts; defaults to "website". */
    ogType?: string;
}

const {
    title,
    description = "A human-readable provenance standard for creative work.",
    canonical = "https://murphysig.dev",
    schemaJson,
    ogType = "website"
} = Astro.props;

const siteTitle = "MurphySig";
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;

const defaultWebsiteSchema = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": siteTitle,
    "description": "A human-readable provenance standard for creative work.",
    "url": "https://murphysig.dev",
    "potentialAction": {
        "@type": "ReadAction",
        "target": "https://murphysig.dev/spec"
    }
};

const renderedSchema = schemaJson ?? defaultWebsiteSchema;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <!-- SEO -->
        <title>{fullTitle}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonical} />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonical} />
        <meta property="og:title" content={fullTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:site_name" content={siteTitle} />

        <!-- Open Graph Image -->
        <meta property="og:image" content="https://murphysig.dev/og-image.png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={fullTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content="https://murphysig.dev/og-image.png" />

        <!-- JSON-LD Structured Data — page-specific when provided, else WebSite default. -->
        <script type="application/ld+json" set:html={JSON.stringify(renderedSchema)} />

        <!-- For AI systems -->
        <link rel="alternate" type="text/plain" href="/llms.txt" title="AI Summary" />
        <link rel="alternate" type="text/plain" href="/spec.txt" title="Plain Text Spec" />

        <!-- Pre-paint: mark JS available so mviz reveal styles apply.
             Without this class, charts render in their final state. -->
        <script is:inline>document.documentElement.classList.add('js');</script>

        <!-- Typography: The Soul of the Project -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter+Tight:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
	</head>
	<body class="antialiased min-h-screen selection:bg-black selection:text-white">
		<main class="max-w-3xl mx-auto px-6 py-20 md:py-32">
            <slot />
        </main>
        
        <footer class="max-w-3xl mx-auto px-6 pb-20 text-sm text-neutral-600 font-mono">
            <nav class="flex flex-wrap gap-x-6 gap-y-2 mb-4">
                <a href="/" class="hover:text-black transition-colors">Home</a>
                <a href="/spec" class="hover:text-black transition-colors">Spec</a>
                <a href="/benchmark" class="hover:text-black transition-colors">Benchmark</a>
                <a href="/signed" class="hover:text-black transition-colors">Registry</a>
                <a href="/whitepaper" class="hover:text-black transition-colors">Whitepaper</a>
                <a href="/about" class="hover:text-black transition-colors">About</a>
                <a href="https://github.com/Round-Tower/murphysig" class="hover:text-black transition-colors">GitHub</a>
                <a href="https://github.com/kpmmmurphy" class="hover:text-black transition-colors">@kpmmmurphy</a>
            </nav>
            <span class="tracking-tight">MurphySig v0.4 <span class="text-neutral-300 mx-2">·</span> <span class="text-neutral-400">murphysig.dev</span></span>
        </footer>

        <script>
            // Scroll-reveal for data graphics + count-up hero figures.
            // Markup always contains final values; this only choreographs
            // how they arrive. Reduced-motion users skip it entirely.
            const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            function countUp(el: HTMLElement) {
                const to = parseFloat(el.dataset.to ?? '');
                if (Number.isNaN(to)) return;
                const decimals = parseInt(el.dataset.decimals ?? '0', 10);
                const prefix = el.dataset.prefix ?? '';
                const suffix = el.dataset.suffix ?? '';
                const duration = 1300;
                let startTime: number | undefined;
                function frame(now: number) {
                    startTime ??= now;
                    const p = Math.min((now - startTime) / duration, 1);
                    const eased = 1 - Math.pow(1 - p, 3);
                    el.textContent = prefix + (to * eased).toFixed(decimals) + suffix;
                    if (p < 1) requestAnimationFrame(frame);
                }
                requestAnimationFrame(frame);
            }

            if (!reduceMotion && 'IntersectionObserver' in window) {
                const observer = new IntersectionObserver((entries) => {
                    for (const entry of entries) {
                        if (!entry.isIntersecting) continue;
                        const el = entry.target as HTMLElement;
                        observer.unobserve(el);
                        if (el.hasAttribute('data-countup')) {
                            countUp(el);
                        } else {
                            el.classList.add('mviz-in');
                        }
                    }
                }, { threshold: 0.35 });

                document.querySelectorAll('.mviz, [data-countup]').forEach((el) => observer.observe(el));
            }
        </script>
	</body>
</html>
